<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#121212"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/button_gradient"
            android:orientation="vertical"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/detail_league_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAllCaps="true"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:text="LEC" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="8dp"
                    android:layout_marginHorizontal="6dp"
                    android:background="#80FFFFFF" />

                <TextView
                    android:id="@+id/detail_serie_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAllCaps="true"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    tools:text="SUMMER 2022" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="8dp"
                    android:layout_marginHorizontal="6dp"
                    android:background="#80FFFFFF" />

                <TextView
                    android:id="@+id/detail_tournament_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAllCaps="true"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    tools:text="PLAYOFFS" />
            </LinearLayout>

            <TextView
                android:id="@+id/detail_match_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="ROUND 3" />
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="18dp">

            <LinearLayout
                android:id="@+id/date_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/detail_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="02/09" />

                <TextView
                    android:id="@+id/detail_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#BDBDBD"
                    android:textSize="10sp"
                    tools:text="17:00" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/score_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/detail_match_type"
                app:layout_constraintStart_toEndOf="@+id/date_container"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/detail_team1_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:maxLines="2"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="FNATIC" />

                <ImageView
                    android:id="@+id/detail_team1_logo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginHorizontal="6dp"
                    tools:src="@tools:sample/avatars" />

                <TextView
                    android:id="@+id/detail_team1_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:text="-"
                    android:textColor="#60FFFFFF"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/detail_team2_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="0" />

                <ImageView
                    android:id="@+id/detail_team2_logo"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginHorizontal="6dp"
                    tools:src="@tools:sample/avatars" />

                <TextView
                    android:id="@+id/detail_team2_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:gravity="start"
                    android:maxLines="2"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="MISFITS" />
            </LinearLayout>

            <TextView
                android:id="@+id/detail_match_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#80BDBDBD"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="BO5" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="10dp">

            <View
                android:id="@+id/indicator_dot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/button_gradient_red" />

            <TextView
                android:id="@+id/detail_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAllCaps="true"
                android:textColor="#FF5252"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="LIVE" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/stream_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#12FFFFFF"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/detail_stream_url"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="middle"
                android:maxWidth="250dp"
                android:singleLine="true"
                android:textColor="#0997B1"
                android:textSize="11sp"
                tools:text="https://www.twitch.tv/lec" />

            <TextView
                android:id="@+id/detail_end_at"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#BDBDBD"
                android:textSize="10sp"
                android:visibility="gone"
                tools:text="Finalizado a las 21:30" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
