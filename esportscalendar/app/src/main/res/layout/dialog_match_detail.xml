<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#121212"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: League, Serie, Tournament, Match Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/button_gradient"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/detail_league_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAllCaps="true"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="LEC" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="12dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="#80FFFFFF" />

                <TextView
                    android:id="@+id/detail_serie_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAllCaps="true"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    tools:text="SUMMER 2022" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="12dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="#80FFFFFF" />

                <TextView
                    android:id="@+id/detail_tournament_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAllCaps="true"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    tools:text="PLAYOFFS" />
            </LinearLayout>

            <TextView
                android:id="@+id/detail_match_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="ROUND 3" />
        </LinearLayout>

        <!-- Main Body: Date, Teams, Score, Game Info -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Date and Time -->
            <LinearLayout
                android:id="@+id/date_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/detail_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="02/09" />

                <TextView
                    android:id="@+id/detail_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#BDBDBD"
                    android:textSize="14sp"
                    tools:text="17:00" />
            </LinearLayout>

            <!-- Team 1 -->
            <LinearLayout
                android:id="@+id/team1_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/score_container"
                app:layout_constraintStart_toEndOf="@+id/date_container"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/detail_team1_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:maxWidth="80dp"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="FNATIC" />

                <ImageView
                    android:id="@+id/detail_team1_logo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    tools:src="@tools:sample/avatars" />
            </LinearLayout>

            <!-- Score -->
            <LinearLayout
                android:id="@+id/score_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/team2_container"
                app:layout_constraintStart_toEndOf="@+id/team1_container"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/detail_team1_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    tools:text="3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="-"
                    android:textColor="#80FFFFFF"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/detail_team2_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    tools:text="0" />
            </LinearLayout>

            <!-- Team 2 -->
            <LinearLayout
                android:id="@+id/team2_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/match_type_container"
                app:layout_constraintStart_toEndOf="@+id/score_container"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/detail_team2_logo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    tools:src="@tools:sample/avatars" />

                <TextView
                    android:id="@+id/detail_team2_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:maxWidth="80dp"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="MISFITS GAMING" />
            </LinearLayout>

            <!-- Match Type (BO1, BO3, BO5) -->
            <LinearLayout
                android:id="@+id/match_type_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/detail_match_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#BDBDBD"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="BO5" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Status & Live/Finished Indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="12dp">

            <View
                android:id="@+id/indicator_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/button_gradient_red" />

            <TextView
                android:id="@+id/detail_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF5252"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="LIVE" />
        </LinearLayout>

        <!-- Streams / End At Link Section -->
        <LinearLayout
            android:id="@+id/stream_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1AFFFFFF"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/detail_stream_url"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#0997B1"
                android:textSize="12sp"
                tools:text="https://www.twitch.tv/lec" />

            <TextView
                android:id="@+id/detail_end_at"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#BDBDBD"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="Finalizado a las 21:30" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
